# Chess 3D — multiplayer configuration
#
# Get these from: https://supabase.com/dashboard → your project → Settings → API
#   * Project URL          → VITE_SUPABASE_URL
#   * "anon public" key    → VITE_SUPABASE_ANON_KEY
#
# The anon key is safe to ship to the browser — RLS policies in
# supabase/migrations/001_init.sql are what actually enforce access control.
# NEVER put the service_role key in this file or in any Vite-built bundle.
#
# Without these set, the single-player paths (hot-seat, vs AI) still work;
# only the online / multiplayer mode requires a configured Supabase project.

VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
